---
const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000';
const demoJwt = import.meta.env.DEMO_JWT ?? '';
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Customer — TCS Orders</title>
  </head>
  <body class="min-h-screen bg-base-200 p-8">
    <div class="max-w-2xl mx-auto">
      <div class="mb-6">
        <a href="/" class="btn btn-ghost btn-sm">← Back</a>
        <h1 class="text-3xl font-bold mt-2">Customer Portal</h1>
      </div>

      <!-- Create Order -->
      <div class="card bg-base-100 shadow mb-6">
        <div class="card-body">
          <h2 class="card-title">Create Order</h2>
          <form id="createForm" class="space-y-4">
            <div class="form-control">
              <label class="label" for="customerId">
                <span class="label-text">Customer ID</span>
              </label>
              <input
                id="customerId"
                name="customerId"
                type="text"
                placeholder="cust-123"
                class="input input-bordered"
                required
              />
            </div>
            <div class="form-control">
              <label class="label" for="amount">
                <span class="label-text">Amount</span>
              </label>
              <input
                id="amount"
                name="amount"
                type="number"
                step="0.01"
                min="0.01"
                placeholder="99.99"
                class="input input-bordered"
                required
              />
            </div>
            <div class="form-control">
              <label class="label" for="currency">
                <span class="label-text">Currency (3-letter ISO)</span>
              </label>
              <input
                id="currency"
                name="currency"
                type="text"
                placeholder="USD"
                maxlength="3"
                pattern="[A-Z]{3}"
                class="input input-bordered uppercase"
                required
              />
            </div>
            <button type="submit" class="btn btn-primary w-full">Place Order</button>
          </form>
          <div id="createResult" class="mt-4 hidden"></div>
        </div>
      </div>

      <!-- Status Lookup -->
      <div class="card bg-base-100 shadow">
        <div class="card-body">
          <h2 class="card-title">Order Status</h2>
          <form id="lookupForm" class="flex gap-2">
            <input
              id="lookupId"
              name="orderId"
              type="text"
              placeholder="Order ID"
              class="input input-bordered flex-1"
              required
            />
            <button type="submit" class="btn btn-secondary">Look up</button>
          </form>
          <div id="lookupResult" class="mt-4 hidden"></div>
        </div>
      </div>
    </div>

    <script define:vars={{ apiUrl, demoJwt }}>
      const headers = {
        'Content-Type': 'application/json',
        Authorization: `Bearer ${demoJwt}`,
      };

      function showResult(el, content, isError = false) {
        el.classList.remove('hidden');
        el.className = el.className.replace(/alert-\w+/g, '');
        el.classList.add('alert', isError ? 'alert-error' : 'alert-success');
        el.innerHTML = content;
      }

      document.getElementById('createForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const fd = new FormData(e.target);
        const body = {
          customerId: fd.get('customerId'),
          amount: Number(fd.get('amount')),
          currency: fd.get('currency').toUpperCase(),
        };
        const resultEl = document.getElementById('createResult');
        try {
          const res = await fetch(`${apiUrl}/orders`, {
            method: 'POST',
            headers,
            body: JSON.stringify(body),
          });
          const data = await res.json();
          if (res.ok) {
            showResult(
              resultEl,
              `<strong>Order created!</strong> ID: <code>${data.id}</code> — Status: <strong>${data.status}</strong>`,
            );
          } else {
            showResult(resultEl, `<strong>Error:</strong> ${JSON.stringify(data)}`, true);
          }
        } catch (err) {
          showResult(resultEl, `<strong>Network error:</strong> ${err.message}`, true);
        }
      });

      document.getElementById('lookupForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const id = document.getElementById('lookupId').value.trim();
        const resultEl = document.getElementById('lookupResult');
        try {
          const res = await fetch(`${apiUrl}/orders/${encodeURIComponent(id)}`, { headers });
          const data = await res.json();
          if (res.ok) {
            showResult(
              resultEl,
              `<div class="space-y-1 text-sm">
                <div><strong>ID:</strong> ${data.id}</div>
                <div><strong>Status:</strong> ${data.status}</div>
                <div><strong>Customer:</strong> ${data.customerId}</div>
                <div><strong>Amount:</strong> ${data.amount} ${data.currency}</div>
                <div><strong>Created:</strong> ${new Date(data.createdAt).toLocaleString()}</div>
                <div><strong>Updated:</strong> ${new Date(data.updatedAt).toLocaleString()}</div>
              </div>`,
            );
          } else if (res.status === 404) {
            showResult(resultEl, 'Order not found.', true);
          } else {
            showResult(resultEl, `<strong>Error:</strong> ${JSON.stringify(data)}`, true);
          }
        } catch (err) {
          showResult(resultEl, `<strong>Network error:</strong> ${err.message}`, true);
        }
      });
    </script>
  </body>
</html>
