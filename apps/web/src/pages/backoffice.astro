---
const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000';
const demoJwt = import.meta.env.DEMO_JWT ?? '';
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Backoffice — TCS Orders</title>
  </head>
  <body class="min-h-screen bg-base-200 p-8">
    <div class="max-w-5xl mx-auto">
      <div class="mb-6 flex items-center justify-between">
        <div>
          <a href="/" class="btn btn-ghost btn-sm">← Back</a>
          <h1 class="text-3xl font-bold mt-2">Backoffice</h1>
        </div>
        <button id="refreshBtn" class="btn btn-outline btn-sm">Refresh</button>
      </div>

      <div class="card bg-base-100 shadow">
        <div class="card-body">
          <div id="content">
            <div class="flex justify-center py-8">
              <span class="loading loading-spinner loading-lg"></span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script is:inline define:vars={{ apiUrl, demoJwt }}>
      const headers = { Authorization: `Bearer ${demoJwt}` };

      function statusBadge(status) {
        const map = {
          PENDING: 'badge-warning',
          PROCESSING: 'badge-info',
          COMPLETED: 'badge-success',
          FAILED: 'badge-error',
        };
        return `<span class="badge ${map[status] ?? 'badge-ghost'}">${status}</span>`;
      }

      async function loadOrders() {
        const contentEl = document.getElementById('content');
        contentEl.innerHTML =
          '<div class="flex justify-center py-8"><span class="loading loading-spinner loading-lg"></span></div>';
        try {
          const res = await fetch(`${apiUrl}/orders`, { headers });
          if (!res.ok) {
            const data = await res.json().catch(() => ({}));
            contentEl.innerHTML = `<div class="alert alert-error"><strong>Error ${res.status}:</strong> ${JSON.stringify(data)}</div>`;
            return;
          }
          const orders = await res.json();
          if (!orders.length) {
            contentEl.innerHTML =
              '<div class="alert alert-info">No orders yet. Create one on the <a href="/customer" class="link">Customer page</a>.</div>';
            return;
          }
          contentEl.innerHTML = `
            <div class="overflow-x-auto">
              <table class="table table-zebra">
                <thead>
                  <tr>
                    <th>ID</th>
                    <th>Status</th>
                    <th>Customer</th>
                    <th>Amount</th>
                    <th>Currency</th>
                    <th>Created</th>
                  </tr>
                </thead>
                <tbody>
                  ${orders
                    .map(
                      (o) => `
                    <tr>
                      <td class="font-mono text-xs">${o.id}</td>
                      <td>${statusBadge(o.status)}</td>
                      <td>${o.customerId}</td>
                      <td class="text-right">${o.amount.toFixed(2)}</td>
                      <td>${o.currency}</td>
                      <td class="text-sm text-base-content/60">${new Date(o.createdAt).toLocaleString()}</td>
                    </tr>`,
                    )
                    .join('')}
                </tbody>
              </table>
            </div>`;
        } catch (err) {
          contentEl.innerHTML = `<div class="alert alert-error"><strong>Network error:</strong> ${err.message}</div>`;
        }
      }

      loadOrders();
      document.getElementById('refreshBtn').addEventListener('click', loadOrders);
    </script>
  </body>
</html>
