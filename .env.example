# Package manager: pnpm. CLI invoked via npx. Copy to .env: `cp .env.example .env`

# --- Adapter selection (per-adapter feature flags) ---
# The composition root (core/orders/composition) picks the concrete adapter per flag.
# Unset/false => in-memory (local). true => AWS adapter.
USE_AWS_SQS=false       # true -> SqsMessagePublisher / SQS consumer; false -> in-memory queue
USE_AWS_DYNAMO=false    # true -> DynamoDB repositories; false -> in-memory repositories

# --- Auth (mock, lightly-signed JWT) ---
JWT_SECRET=change-me-in-local-only

# --- Processing simulation ---
# FakePaymentGateway DECLINES authorization when amount > this threshold -> order FAILED.
FAIL_ABOVE_AMOUNT=10000

# --- DynamoDB (used when USE_AWS_DYNAMO=true; DDB_ENDPOINT for local dynamodb) ---
ORDERS_TABLE=orders
AWS_REGION=us-east-1
DDB_ENDPOINT=http://localhost:8000

# --- SQS (used when USE_AWS_SQS=true) ---
QUEUE_URL=

# --- Local runtime ---
PORT=3000
